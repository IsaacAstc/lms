rules_version = '2';

// 항공보안 교육 운영관리 시스템 보안규칙.
// 수동 배포용. Firebase 콘솔 또는 `firebase deploy --only firestore:rules` 로 반영.
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자(인증된 사용자) 여부.
    function isAdmin() {
      return request.auth != null;
    }

    // 과정·차수 마스터: 읽기·쓰기 모두 관리자 전용.
    match /courses/{courseId} {
      allow read, write: if isAdmin();
    }

    // 강의 시간표: 읽기·쓰기 모두 관리자 전용.
    match /sessions/{sessionId} {
      allow read, write: if isAdmin();
    }

    // 강의실 마스터: 관리자 전용.
    match /rooms/{roomId} {
      allow read, write: if isAdmin();
    }

    // 강사 마스터(개인정보 예외 — 강사에 한함): 관리자 전용, 공개 금지.
    match /instructors/{instructorId} {
      allow read, write: if isAdmin();
    }

    // 과정 커리큘럼 마스터: 관리자 전용.
    match /programs/{programId} {
      allow read, write: if isAdmin();
    }

    // 기준값 설정(강사료·여비): 관리자 전용.
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // 공개 설문 정의: 누구나 읽기(응답 페이지 렌더), 쓰기는 관리자만.
    match /publicSurveys/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 설문 응답: create 만 공개 허용(완전 익명), 읽기·수정·삭제는 관리자만.
    // expireAt은 서버시각 기준 약 180일 후여야 함(클라이언트 조작 방지, ±2일 허용).
    match /surveyResponses/{responseId} {
      allow create: if request.resource.data.expireAt is timestamp
        && request.resource.data.expireAt > request.time + duration.value(178, 'd')
        && request.resource.data.expireAt < request.time + duration.value(182, 'd');
      allow read, update, delete: if isAdmin();
    }

    // 집계 데이터(영구 보관): 관리자 전용.
    match /surveyAggregates/{aggregateId} {
      allow read, write: if isAdmin();
    }
  }
}
